---
import BaseLayout from '@components/layout/BaseLayout.astro';
import TableOfContents from '@components/blog/TableOfContents.astro';
import { getConfig } from '@lib/config';
import { formatDate, calculateReadingTime } from '@lib/utils';
import { getCollection, render } from 'astro:content';

const config = getConfig();
if (!config.pages.blog) return Astro.redirect('/404');

type BlogLang = 'en' | 'es';

const languageLabel: Record<BlogLang, string> = {
  en: 'English',
  es: 'Español',
};

const rawPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = rawPosts
  .map((entry) => ({
    entry,
    slug: entry.slug,
    title: entry.data.title,
    date: entry.data.date,
    description: entry.data.description,
    tags: entry.data.tags ?? [],
    lang: (entry.data.lang ?? 'en') as BlogLang,
    translationKey: entry.data.translationKey ?? entry.slug,
    readingTime: calculateReadingTime(entry.body),
  }))
  .sort((a, b) => b.date.getTime() - a.date.getTime());

const { slug } = Astro.params;
const post = posts.find((item) => item.slug === slug);

if (!post) return Astro.redirect('/404');

const sameLanguagePosts = posts.filter((item) => item.lang === post.lang);
const postIndex = sameLanguagePosts.findIndex((item) => item.slug === post.slug);
const prevPost = postIndex < sameLanguagePosts.length - 1 ? sameLanguagePosts[postIndex + 1] : null;
const nextPost = postIndex > 0 ? sameLanguagePosts[postIndex - 1] : null;

const translations = posts
  .filter((item) => item.translationKey === post.translationKey)
  .sort((a, b) => a.lang.localeCompare(b.lang));

const { Content, headings } = await render(post.entry);
export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}
---

<BaseLayout title={post.title} description={post.description}>
  <article class="max-w-4xl mx-auto">
    <div id="reading-progress" class="fixed top-0 left-0 h-0.5 bg-[var(--color-accent)] z-[60] transition-all" style="width: 0%"></div>

    <header class="mb-10 animate-on-scroll">
      <div class="flex flex-wrap items-center justify-between gap-3 mb-4">
        <div class="flex flex-wrap gap-2">
          {post.tags.map((tag) => (
            <a href={`/blog?tag=${tag}`} class="px-2.5 py-0.5 rounded-full text-xs font-medium bg-[var(--color-accent)]/10 text-[var(--color-accent)]">{tag}</a>
          ))}
        </div>

        {translations.length > 1 && (
          <div class="inline-flex rounded-full border border-[var(--color-border)] bg-[var(--color-card-bg)] p-1">
            {translations.map((item) => (
              <a
                href={`/blog/${item.slug}`}
                class={`px-3 py-1 rounded-full text-xs font-medium transition-colors ${item.slug === post.slug ? 'bg-[var(--color-accent)] text-white' : 'text-[var(--color-text-secondary)] hover:text-[var(--color-accent)]'}`}
                aria-current={item.slug === post.slug ? 'page' : undefined}
              >
                {languageLabel[item.lang]}
              </a>
            ))}
          </div>
        )}
      </div>

      <h1 class="text-3xl md:text-4xl font-bold leading-tight">{post.title}</h1>
      <div class="mt-4 flex items-center gap-4 text-sm text-[var(--color-text-secondary)]">
        <time class="font-mono">{formatDate(post.date)}</time>
        <span>&middot;</span>
        <span>{post.readingTime} min read</span>
      </div>
    </header>

    <div class="flex gap-10">
      <div class="prose flex-1 min-w-0">
        <Content />
      </div>

      {headings.length > 2 && config.blog.show_table_of_contents && (
        <aside class="hidden xl:block w-56 shrink-0">
          <TableOfContents headings={headings.filter((heading) => heading.depth === 2 || heading.depth === 3)} />
        </aside>
      )}
    </div>

    <nav class="mt-16 pt-8 border-t border-[var(--color-border)] grid grid-cols-2 gap-4">
      {prevPost ? (
        <a href={`/blog/${prevPost.slug}`} class="group p-4 rounded-xl border border-[var(--color-border)] hover:border-[var(--color-accent)]/50 transition-colors">
          <span class="text-xs text-[var(--color-text-secondary)]">&larr; Previous</span>
          <p class="mt-1 font-medium group-hover:text-[var(--color-accent)] transition-colors">{prevPost.title}</p>
        </a>
      ) : <div />}
      {nextPost ? (
        <a href={`/blog/${nextPost.slug}`} class="group p-4 rounded-xl border border-[var(--color-border)] hover:border-[var(--color-accent)]/50 transition-colors text-right">
          <span class="text-xs text-[var(--color-text-secondary)]">Next &rarr;</span>
          <p class="mt-1 font-medium group-hover:text-[var(--color-accent)] transition-colors">{nextPost.title}</p>
        </a>
      ) : <div />}
    </nav>
  </article>

  <script>
    document.addEventListener('astro:page-load', () => {
      const bar = document.getElementById('reading-progress');
      if (!bar) return;
      window.addEventListener('scroll', () => {
        const h = document.documentElement.scrollHeight - window.innerHeight;
        bar.style.width = h > 0 ? `${(window.scrollY / h) * 100}%` : '0%';
      });
    });
  </script>
</BaseLayout>
